{
  "name": "work-buddy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter=runtime run dev",
    "mcp:gmail": "bun --filter=tool-gmail run mcp",
    "mcp:github": "bun --filter=tool-github run mcp",
    "mcp:correlation": "bun --filter=tool-correlation run mcp",
    "mcp:scheduler": "bun --filter=tool-scheduler run mcp",
    "check": "biome check",
    "check:fix": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint",
    "typecheck": "bun --workspaces run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
